---
interface Props {
  title: string;
  description?: string;
  beforeLabel?: string;
  afterLabel?: string;
}

const {
  title,
  description,
  beforeLabel = 'Before',
  afterLabel = 'Saved rule',
} = Astro.props;
---

<section class="rounded-lg border border-border bg-card p-5">
  <div class="flex flex-col gap-2">
    <p class="text-xs font-medium uppercase tracking-wide text-primary">{afterLabel}</p>
    <h3 class="text-xl font-semibold text-card-foreground">{title}</h3>
    {description && <p class="text-sm leading-relaxed text-muted-foreground">{description}</p>}
  </div>
  <div class="mt-5 grid gap-4 md:grid-cols-[0.8fr_1.2fr]">
    <div class="rounded-md border border-border bg-background p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">{beforeLabel}</p>
      <p class="mt-3 text-sm leading-relaxed text-card-foreground">
        Repeated form tests, copied sample data, and the same manual field entry every time you open the site.
      </p>
    </div>
    <div class="overflow-hidden rounded-md border border-border bg-background">
      <slot />
    </div>
  </div>
</section>
