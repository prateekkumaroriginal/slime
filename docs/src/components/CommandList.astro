---
interface Props {
  commands: string[];
}

const { commands } = Astro.props;
---

<div class="rounded-lg border border-border bg-card p-3">
  <div class="flex items-center gap-2 border-b border-border px-2 pb-3 text-sm text-muted-foreground">
    <span class="text-primary">⌘</span>
    <span>Try these as saved rules</span>
  </div>
  <div class="flex flex-col gap-1 pt-3">
    {
      commands.map((command) => (
        <div class="flex items-center justify-between gap-3 rounded-md px-3 py-2 text-sm text-card-foreground hover:bg-accent hover:text-accent-foreground">
          <span>{command}</span>
          <span class="text-muted-foreground">↵</span>
        </div>
      ))
    }
  </div>
</div>
