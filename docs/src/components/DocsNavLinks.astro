---
import SlimeLinkCard from './SlimeLinkCard.astro';

interface NavLinkItem {
  title: string;
  href: string;
  description?: string;
  rel?: string;
}

interface Props {
  links: NavLinkItem[];
  ariaLabel?: string;
}

const { links, ariaLabel = 'Related documentation' } = Astro.props;
---

{
  links.length > 0 && (
    <nav
      class="grid grid-cols-1 gap-4 sm:grid-cols-2"
      aria-label={ariaLabel}
    >
      {links.map((link) => (
        <SlimeLinkCard
          title={link.title}
          href={link.href}
          description={link.description}
          rel={link.rel}
        />
      ))}
    </nav>
  )
}
